{
  "name": "accountabilityof",
  "description": "AI incident reporting + tamper-evident audit trail.",
  "url": "https://accountabilityof.ai",
  "version": "0.1.0",
  "provider": {
    "organization": "CSOAI-ORG",
    "url": "https://csoai.org"
  },
  "capabilities": {
    "streaming": true,
    "pushNotifications": false,
    "stateTransitionHistory": true
  },
  "defaultInputModes": [
    "text"
  ],
  "defaultOutputModes": [
    "text",
    "json"
  ],
  "skills": [
    {
      "id": "ai-incident-reporting-mcp",
      "name": "ai-incident-reporting-mcp",
      "description": "Tool: ai-incident-reporting-mcp (part of accountabilityof.ai hive L5)"
    },
    {
      "id": "ai-self-audit-mcp",
      "name": "ai-self-audit-mcp",
      "description": "Tool: ai-self-audit-mcp (part of accountabilityof.ai hive L5)"
    },
    {
      "id": "a2a-governance-bridge-mcp",
      "name": "a2a-governance-bridge-mcp",
      "description": "Tool: a2a-governance-bridge-mcp (part of accountabilityof.ai hive L5)"
    },
    {
      "id": "a2a-mesh",
      "name": "Cross-hive A2A call",
      "description": "Can call other MEOK hives via A2A (with user consent)"
    },
    {
      "id": "memoria-commit",
      "name": "Versioned memory commit",
      "description": "Commits to memoria namespace 'accountabilityof'"
    }
  ],
  "securitySchemes": {
    "oauth2": {
      "type": "oauth2",
      "flows": {
        "authorizationCode": {
          "authorizationUrl": "https://accountabilityof.ai/oauth/authorize",
          "tokenUrl": "https://accountabilityof.ai/oauth/token",
          "scopes": {
            "read": "Read hive state",
            "write": "Invoke tools (x402-metered)",
            "audit": "Read audit trail"
          }
        }
      }
    }
  },
  "x402Pricing": {
    "enabled": true,
    "currency": "USD",
    "amount": "0.50",
    "freeCallsPerIPPerDay": "1"
  }
}
